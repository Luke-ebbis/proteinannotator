// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core subworkflows test hmmer

nextflow_workflow {

    name "Test Workflow HMMER"
    script "../main.nf"
    workflow "HMMER"

    test("Test HMMER database preparation and search") {

        when {
            workflow {
                """
                // Create test protein channel
                input[0] = Channel.of(
                    [
                        [ id:'test_protein' ],
                        file("${projectDir}/test-datasets/proteins/test.fasta", checkIfExists: true)
                    ]
                )
                
                // Create test HMM database channel (unpressed)
                input[1] = Channel.of(
                    [
                        [ id:'test_hmm' ],
                        file("${projectDir}/test-datasets/hmm/test.hmm", checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert workflow.out.pressed_db
            assert workflow.out.search_results
            assert workflow.out.domtblout
            assert workflow.out.versions
        }
    }
}


    
